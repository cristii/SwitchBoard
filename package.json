{
  "name": "switchboard-playground",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck && tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "prisma": "^6.10.1",
    "tsx": "^4.19.4",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
